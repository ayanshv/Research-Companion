{
  "manifest_version": 3,
  "name": "Synapse - Research Companion",
  "version": "1.0",
  "description": "Summarize and save research pages with AI",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
  "16": "favicon.png",
  "48": "favicon.png",
  "128": "favicon.png"
},
"action": {
  "default_popup": "popup.html",
  "default_icon": "favicon.png"
},
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}

